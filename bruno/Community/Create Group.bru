meta {
  name: Create Group
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/community/groups
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "name": "Maternal Health Kano",
    "description": "A group for maternal health discussions in Kano state",
    "category": "maternal",
    "language": "hausa"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("groupId", res.body.group._id);
  }
}
