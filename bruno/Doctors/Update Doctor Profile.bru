meta {
  name: Update Doctor Profile
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/api/doctors/profile
  body: json
  auth: bearer
}

auth:bearer {
  token: {{doctorToken}}
}

body:json {
  {
    "specialization": "general",
    "licenseNumber": "MDCN-12345",
    "hospital": "Aminu Kano Teaching Hospital"
  }
}
