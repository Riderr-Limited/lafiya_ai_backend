meta {
  name: Register Admin
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "name": "Admin User",
    "phone": "08099999999",
    "password": "admin123",
    "role": "admin",
    "language": "english"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("adminToken", res.body.token);
  }
}
