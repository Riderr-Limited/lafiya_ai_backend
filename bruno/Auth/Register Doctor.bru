meta {
  name: Register Doctor
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "name": "Dr. Fatima Bello",
    "phone": "08077777777",
    "password": "doctor123",
    "role": "doctor",
    "language": "english"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("doctorToken", res.body.token);
    bru.setVar("doctorId", res.body.user._id);
  }
}
