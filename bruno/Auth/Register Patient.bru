meta {
  name: Register Patient
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "name": "Aminu Musa",
    "phone": "08012345678",
    "password": "password123",
    "role": "patient",
    "language": "hausa"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("token", res.body.token);
  }
}
